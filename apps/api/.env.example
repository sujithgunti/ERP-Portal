# API (NestJS) + Prisma — auto-loaded by Nest ConfigModule and the Prisma CLI
# (both run with cwd = apps/api in this Turborepo). Copy to apps/api/.env.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# JWT signing secret — MUST equal the web app's AUTH_SECRET.
JWT_SECRET="dev-secret-change-me"

# API listens on :8000; CORS allows the web origin (:8001).
PORT=8000
WEB_ORIGIN="http://localhost:8001"
