// ERP Portal — Prisma schema (MVP)
// Source of truth: docs/01-product-spec.md (§4 stages, §5 entities, §6 permissions)
// Domain: eco-bag factory — clients, orders, 9-stage production tracking, RBAC.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

/// Known RBAC role codes. New roles can be added here and seeded into
/// role_definitions; RoleDefinition.role links a row to its enum code.
enum UserRole {
  ADMIN
  SUPERVISOR
  PARTNER
}

/// Order priority (spec §5).
enum Priority {
  HIGH
  MEDIUM
  LOW
}

/// Order lifecycle status (spec §5).
enum OrderStatus {
  ACTIVE
  DELAYED
  DELIVERED
}

/// The nine ordered production stages (spec §4). `currentStage` points at one.
enum ProductionStage {
  PAPER_PROCUREMENT
  PRINTING
  DESIGNING
  LAMINATION
  PUNCHING
  IN_HOUSE_MANUFACTURING
  HANDLE_PASTING
  PACKING
  DISPATCH
  DELIVERED
}

/// Direction of a daily cash entry (the daily expense / cash book).
enum ExpenseDirection {
  INCOMING
  OUTGOING
}

/// A worker's status for a single day.
enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

// ─────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────

/// System user. Auth + RBAC. Each user has exactly one role (via UserRoleAssignment).
model User {
  id             String              @id @default(uuid()) @db.Uuid
  name           String
  email          String              @unique
  passwordHash   String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Exactly one role assignment per user (carries the per-user permission bitmask).
  roleAssignment UserRoleAssignment?
  // Daily updates this user recorded (Admin) — see DailyUpdate.updatedBy.
  dailyUpdates   DailyUpdate[]
}

/// Dynamic RBAC role. Roles live in a table so new ones can be added without a
/// schema change. `permissions` is the role's DEFAULT tab bitmask (Discord-style;
/// one bit per tab, see TAB in @erp/types) used to seed a new user's assignment.
model RoleDefinition {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role        UserRole? @unique
  code        String    @unique @db.VarChar(50)
  definition  String    @db.VarChar(500)
  permissions BigInt    @default(0) @db.BigInt

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userAssignments UserRoleAssignment[]

  @@map("role_definitions")
}

/// Maps a user to their role + that user's effective tab permission bitmask.
/// One row per user (single role per user).
model UserRoleAssignment {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String         @unique @map("user_id") @db.Uuid
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDefinitionId String         @map("role_definition_id") @db.Uuid
  roleDefinition   RoleDefinition @relation(fields: [roleDefinitionId], references: [id])
  permissions      BigInt         @default(0) @db.BigInt

  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([roleDefinitionId])
  @@map("user_role_assignments")
}

/// A client the factory produces orders for.
model Client {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  gstNumber String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
}

/// A production order. Travels through the 9 stages to DELIVERED.
model Order {
  id           String          @id @default(uuid()) @db.Uuid
  orderCode    String          @unique // e.g. ORD-001
  name         String
  quantity     Int
  deadline     DateTime
  priority     Priority        @default(MEDIUM)
  status       OrderStatus     @default(ACTIVE)
  currentStage ProductionStage @default(PAPER_PROCUREMENT)

  // Specifications (spec §5) — structured columns for MVP.
  size         String?
  gsm          Int?
  printingType String?
  handleType   String?
  lamination   Boolean         @default(false)

  // Free-text additional notes / message for the order.
  notes        String?         @db.Text

  // Relations
  clientId     String          @db.Uuid
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dailyUpdates DailyUpdate[]
  cost         OrderCost?

  // Timestamps
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deliveredAt  DateTime?

  @@index([clientId])
  @@index([status])
  @@index([deadline])
}

/// One daily production update for an order (spec §3, §5).
/// Records progress within a stage; `verified` set by Supervisor (spec §6).
model DailyUpdate {
  id                String          @id @default(uuid()) @db.Uuid
  date              DateTime        @default(now())
  stage             ProductionStage
  quantityCompleted Int             @default(0)
  quantityPending   Int             @default(0)
  remarks           String?
  verified          Boolean         @default(false)

  // Relations
  orderId           String          @db.Uuid
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  updatedById       String          @db.Uuid
  updatedBy         User            @relation(fields: [updatedById], references: [id])

  createdAt         DateTime        @default(now())

  @@index([orderId])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// Costing — per-order cost breakdown (overhead entered manually)
// ─────────────────────────────────────────────────────────────

/// Per-order cost configuration. Material lines + overhead-per-bag are entered
/// manually. cost-per-bag is computed live (material + overhead), not stored.
model OrderCost {
  id                 String         @id @default(uuid()) @db.Uuid
  orderId            String         @unique @db.Uuid
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Overhead per bag, typed by the admin (₹/bag).
  overheadPerBag     Decimal?       @db.Decimal(10, 4)

  sellingPricePerBag Decimal?       @db.Decimal(10, 4)
  note               String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  materialLines      MaterialLine[]
}

/// One material cost line for an order (e.g. Paper 5.06 / bag). Sum = material-per-bag.
model MaterialLine {
  id          String    @id @default(uuid()) @db.Uuid
  orderCostId String    @db.Uuid
  orderCost   OrderCost @relation(fields: [orderCostId], references: [id], onDelete: Cascade)
  name        String
  costPerBag  Decimal   @db.Decimal(10, 4)
  createdAt   DateTime  @default(now())

  @@index([orderCostId])
}

// ─────────────────────────────────────────────────────────────
// Daily expenses — incoming / outgoing cash book
// ─────────────────────────────────────────────────────────────

/// One cash entry on a given day. Daily net = Σ INCOMING − Σ OUTGOING.
model DailyExpense {
  id        String           @id @default(uuid()) @db.Uuid
  date      DateTime         @db.Date
  direction ExpenseDirection
  amount    Decimal          @db.Decimal(12, 2)
  category  String? // freetext, e.g. "Paper", "Client advance", "Labour"
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// Workforce — workers + daily attendance
// ─────────────────────────────────────────────────────────────

/// A factory worker. Attendance is marked per day (see Attendance).
model Worker {
  id         String       @id @default(uuid()) @db.Uuid
  name       String
  phone      String?
  role       String? // freetext, e.g. "Machine operator", "Ladies work", "Helper"
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  attendance Attendance[]

  @@index([active])
}

/// One worker's status on one calendar day. Unique per (worker, day).
model Attendance {
  id        String           @id @default(uuid()) @db.Uuid
  workerId  String           @db.Uuid
  worker    Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus
  checkIn   String? // "HH:MM" 24h, e.g. "10:00"
  checkOut  String? // "HH:MM" 24h, e.g. "14:00"
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([workerId, date])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// Work efficiency — machines + daily bag-production count
// ─────────────────────────────────────────────────────────────

/// A production machine. Daily output is recorded per machine.
model Machine {
  id         String              @id @default(uuid()) @db.Uuid
  name       String
  type       String? // freetext, e.g. "Punching", "Side pasting"
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  production MachineProduction[]

  @@index([active])
}

/// Bags produced by one machine on one calendar day. Unique per (machine, day).
model MachineProduction {
  id           String   @id @default(uuid()) @db.Uuid
  machineId    String   @db.Uuid
  machine      Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  bagsProduced Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([machineId, date])
  @@index([date])
}
