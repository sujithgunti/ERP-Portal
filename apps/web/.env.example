# Web (Next.js / Auth.js) — auto-loaded by Next.js from apps/web.
# Copy to apps/web/.env.local.

# Auth.js secret — MUST equal the API's JWT_SECRET.
AUTH_SECRET="dev-secret-change-me"

# Web origin (dev server runs on :8001) and the API origin it calls.
NEXTAUTH_URL="http://localhost:8001"
NEXT_PUBLIC_API_URL="http://localhost:8000"
