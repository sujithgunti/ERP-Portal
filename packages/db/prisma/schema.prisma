// ERP Portal — Prisma schema (MVP)
// See docs/03-architecture.md §5 for the data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  PARTNER
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum OrderStatus {
  ACTIVE
  DELAYED
  DELIVERED
}

enum ProductionStage {
  PAPER_PROCUREMENT
  PRINTING
  LAMINATION
  PUNCHING
  IN_HOUSE_MANUFACTURING
  HANDLE_PASTING
  PACKING
  DISPATCH
  DELIVERED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role          @default(PARTNER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  dailyUpdates DailyUpdate[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id           String          @id @default(cuid())
  orderCode    String          @unique
  name         String
  quantity     Int
  deadline     DateTime
  priority     Priority        @default(MEDIUM)
  status       OrderStatus     @default(ACTIVE)
  currentStage ProductionStage @default(PAPER_PROCUREMENT)

  // Specifications (structured for MVP — see architecture doc)
  size         String?
  gsm          Int?
  printingType String?
  handleType   String?
  lamination   Boolean         @default(false)

  clientId     String
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  dailyUpdates DailyUpdate[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deliveredAt  DateTime?

  @@index([clientId])
  @@index([status])
}

model DailyUpdate {
  id                String          @id @default(cuid())
  date              DateTime        @default(now())
  stage             ProductionStage
  quantityCompleted Int             @default(0)
  quantityPending   Int             @default(0)
  remarks           String?
  verified          Boolean         @default(false)

  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  updatedById       String
  updatedBy         User            @relation(fields: [updatedById], references: [id])

  createdAt         DateTime        @default(now())

  @@index([orderId])
}
