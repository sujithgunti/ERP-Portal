{
  "name": "erp-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @erp/db generate",
    "db:push": "pnpm --filter @erp/db push",
    "db:migrate": "pnpm --filter @erp/db migrate",
    "db:seed": "pnpm --filter @erp/db seed",
    "db:studio": "pnpm --filter @erp/db studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
